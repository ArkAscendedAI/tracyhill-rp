# ═══════════════════════════════════════════════════════════
# TracyHill RP — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed.

# ── Email (SendGrid) ──
# Required for MFA, registration, and forgot password
SENDGRID_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=TracyHill

# ── MFA Settings ──
# MFA_TRUST_DAYS=30

# ── Claude Code Agent Proxy (optional, admin feature) ──
# CLAUDE_CODE_HOST=
# CLAUDE_CODE_PORT=7700
# CLAUDE_CODE_SECRET=
# CLAUDE_CODE_CA_PATH=certs/claude-agent.pem

# ── Codex Agent Proxy (optional, admin feature) ──
# CODEX_HOST=
# CODEX_PORT=7701
# CODEX_SECRET=
# CODEX_CA_PATH=certs/codex-agent.pem
